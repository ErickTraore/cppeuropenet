# =============================================================================
# Ports et variables FIGÉS pour Cypress / E2E — fichier VERSIONNÉ.
# À ne modifier qu’en même temps que :
#   - frontend/services-inventory.json
#   - frontend/scripts/wait-e2e-services.js (+ baseUrl Cypress :8082)
#   - mappings de ports des stacks Contabo (7004, 7005, 7008, 7012, 7017, 7020)
#
# Démarrage recommandé : ./scripts/e2e-compose.sh up -d
# (équivalent : docker compose --env-file ./docker-compose.e2e.env -f docker-compose.yml up -d)
# =============================================================================

# --- Ports hôte → conteneur (ne pas changer pour des runs Cypress répétables) ---
COMPOSE_MARIADB_HOST_PORT=3314
COMPOSE_USER_BACKEND_HOST_PORT=17001
COMPOSE_NGINX_HOST_PORT=8085
COMPOSE_FRONTEND_HOST_PORT=8082
COMPOSE_ADMINER_HOST_PORT=8083
COMPOSE_ADMINER_DB_HOST=mariadb

# --- MariaDB (image officielle) — aligner avec user-backend si besoin ---
MARIADB_DATABASE=user_dev_cppeurope_v1
MARIADB_USER=c
MARIADB_PASSWORD=CppEurope@2025!
MARIADB_ROOT_PASSWORD=RootPass@2025!

# --- CORS ---
COMPOSE_USER_BACKEND_ALLOWED_ORIGINS=https://cppeurope.net,https://www.cppeurope.net,http://localhost:8082,http://localhost:3000,http://127.0.0.1:8082,http://127.0.0.1:3000
COMPOSE_USER_BACKEND_ALLOW_PRIVATE_LAN_ORIGINS=true
COMPOSE_HOME_CONFIG_ALLOWED_ORIGINS=https://cppeurope.net,https://www.cppeurope.net,http://localhost:8082,http://localhost:3000,http://localhost:8085,http://127.0.0.1:8082,http://127.0.0.1:8085

# --- Node (surcharges compose) ---
COMPOSE_USER_BACKEND_NODE_ENV=production
COMPOSE_HOME_CONFIG_NODE_ENV=production

# --- home-config (service interne ; proxy front HTTP interne) ---
COMPOSE_HOME_CONFIG_PORT=7020
COMPOSE_HOME_CONFIG_DATA_DIR=/data
COMPOSE_HOME_CONFIG_MAX_UPLOAD_MB=50

# --- Frontend (server.prod.js) : proxy vers Contabo / APIs presse ---
NODE_ENV=production
REACT_APP_USER_API=/api/users
USER_BACKEND_HOST=user-backend
USER_BACKEND_PORT=7001
HOME_CONFIG_HOST=home-config
HOME_CONFIG_PORT=7020
PROXY_UPSTREAM_HOST_HEADER=cppeurope.net
MEDIA_STATIC_HOST=host.docker.internal
MEDIA_STATIC_PORT=7017
MEDIA_HEALTH_PATH=/api/user-media-profile/
PRESSE_MEDIA_GLE_HOST=host.docker.internal
PRESSE_MEDIA_GLE_PORT=7004
PRESSE_MEDIA_LOC_HOST=host.docker.internal
PRESSE_MEDIA_LOC_PORT=7008
PRESSE_LOCALE_MSG_HOST=host.docker.internal
PRESSE_LOCALE_MSG_PORT=7005
PRESSE_GENERALE_HOST=host.docker.internal
PRESSE_GENERALE_PORT=17012
