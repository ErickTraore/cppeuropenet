# Copier vers docker-compose.development.env (non versionné) et adapter.
# Démarrage : ./scripts/dev-compose.sh up -d
# ou : docker compose --env-file ./docker-compose.development.env -f docker-compose.dev.yml up -d
#
# Les identifiants MariaDB doivent rester alignés avec user-backend/.env.development (DB_NAME, DB_USERNAME, DB_PASSWORD).

# --- Ports hôte ---
COMPOSE_USER_BACKEND_HOST_PORT=7001
COMPOSE_MARIADB_HOST_PORT=3307

# --- MariaDB (image officielle) ---
MARIADB_DATABASE=user_dev_cppeurope_v1
MARIADB_USER=c
MARIADB_PASSWORD=CppEurope@2025!
MARIADB_ROOT_PASSWORD=CppEurope@2025!

# --- Surcharges pour le conteneur user-backend (réseau Docker) ---
COMPOSE_USER_BACKEND_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8082
COMPOSE_USER_BACKEND_DB_HOST=mariadb
# Depuis le conteneur : host-gateway = machine hôte (userMediaProfile en 7017 sur l’hôte)
COMPOSE_REACT_APP_MEDIA_API=http://host.docker.internal:7017/api/user-media-profile
COMPOSE_MEDIA_API_CONTABO=http://host.docker.internal:7017/api/user-media-profile
