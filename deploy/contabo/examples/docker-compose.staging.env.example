# Copier vers docker-compose.staging.env sur le VPS (non versionné avec secrets).
# Utilisation : docker compose --env-file ./docker-compose.staging.env -f docker-compose.staging.yml …

# Images
COMPOSE_NODE_IMAGE=node:20
COMPOSE_MARIADB_IMAGE=mariadb:11

# Ports : hôte (souvent 127.0.0.1 dans nginx) → conteneur applicatif
# Ex. staging presse média générale : loopback 17004 → app 7004 (voir deploy/CONTABO-VPS-STAGING.md)
STAGING_LOOPBACK_HOST_PORT=17004
CONTAINER_APP_PORT=7004

COMPOSE_NODE_ENV=production

# Contenu du `sh -c` (une ligne ; guillemets évités côté YAML)
COMPOSE_APP_SHELL_COMMAND=npm install && node server.prod.js

# MariaDB (si présent dans le même compose)
# STAGING_MARIADB_HOST_PORT=13306
# MARIADB_DATABASE=media_staging_cppeurope_v1
# MARIADB_USER=…
# MARIADB_PASSWORD=…
# MARIADB_ROOT_PASSWORD=…
