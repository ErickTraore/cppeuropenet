COMPOSE_NODE_IMAGE=node:20-alpine
COMPOSE_MARIADB_IMAGE=mariadb:11
COMPOSE_APP_SHELL_COMMAND=npm install --omit=dev && node server.prod.js
NODE_ENV=production
PROD_BIND_HOST=0.0.0.0
PROD_HOST_PORT=7020
CONTAINER_APP_PORT=7020
MARIADB_DATABASE=home_config_prod_cppeurope_v1
MARIADB_USER=c
MARIADB_PASSWORD=CHANGE_ME
MARIADB_ROOT_PASSWORD=CHANGE_ME
COMPOSE_HOME_CONFIG_NET_NAME=home-config-net
