COMPOSE_NODE_IMAGE=node:18-alpine
COMPOSE_MARIADB_IMAGE=mariadb:11
COMPOSE_APP_SHELL_COMMAND=npm install --only=production && node server.prod.js
STAGING_BIND_HOST=127.0.0.1
STAGING_MEDIA_LOCALE_HOST_PORT=17006
CONTAINER_MEDIA_LOCALE_PORT=7006
STAGING_UMP_HOST_PORT=17007
CONTAINER_UMP_PORT=7007
MARIADB_DATABASE=media_locale_staging_cppeurope_v1
MARIADB_USER=c
COMPOSE_MEDIA_LOCALE_PATH=../mediaLocale-backend
COMPOSE_MEDIA_LOCALE_UPLOADS_PATH=../mediaLocale-backend/uploads-staging
COMPOSE_USER_MEDIA_PROFILE_PATH=../userMediaProfile-backend
COMPOSE_USER_MEDIA_PROFILE_UPLOADS_PATH=../userMediaProfile-backend/uploads-staging
