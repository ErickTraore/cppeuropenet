COMPOSE_NODE_IMAGE=node:20-alpine
COMPOSE_APP_SHELL_COMMAND=npm install --omit=dev && node server.prod.js
NODE_ENV=production
COMPOSE_APP_PORT=7016
CONTAINER_PORT=7016
PROD_BIND_HOST=0.0.0.0
PROD_HOST_PORT=7016
COMPOSE_ALLOWED_ORIGINS=https://cppeurope.net,https://www.cppeurope.net,http://localhost:8082
