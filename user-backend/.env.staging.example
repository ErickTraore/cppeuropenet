# Copier vers .env.staging et adapter (ne pas commiter .env.staging avec des secrets réels si le dépôt est public).
# Utilisé avec docker-compose.staging.env (voir docker-compose.staging.env.example) :
#   ./scripts/staging-compose.sh …
# ou : docker compose --env-file ./user-backend/.env.staging --env-file ./docker-compose.staging.env -f docker-compose.staging.yml -p cppeurope-staging …

# --- MariaDB (conteneur + Sequelize) : base STRICTEMENT distincte de la prod ---
DB_USERNAME=staging_cpp_user
DB_PASSWORD=CHANGE_ME_staging_db_password
DB_HOST=mariadb
DB_PORT=3306
DB_DIALECT=mariadb
DB_NAME=user_staging_cppeurope_v1

# Mot de passe root du conteneur MariaDB staging (indépendant de la prod)
MARIADB_ROOT_PASSWORD=CHANGE_ME_staging_root_password

PORT=7001

EXPIRE_EXTEND_SESSION=30m
EXPIRE_SESSION=30m

# Secrets JWT dédiés au staging (ne pas réutiliser ceux de la prod)
JWT_REFRESH_SECRET=CHANGE_ME_staging_refresh_secret_min_32_chars
JWT_SIGN_SECRET=CHANGE_ME_staging_sign_secret_min_32_chars

# URLs publiques du site staging (remplacer par votre sous-domaine ou http://IP:9085)
REACT_APP_URL=https://staging.cppeurope.net
REACT_APP_USER_API=https://staging.cppeurope.net/api/users
REACT_APP_MEDIA_API=https://staging.cppeurope.net/api/media

# Origines autorisées CORS : doit inclure l’URL vue par le navigateur (même host:port que nginx staging 9085 si accès par IP)
ALLOWED_ORIGINS=https://staging.cppeurope.net,http://127.0.0.1:9085,http://localhost:9085

# Backends médias / presse : VPS Contabo — chemin préfixé /cppeurope-staging (isolation d’URL ; voir deploy/contabo-cppeurope-staging-prefix.conf.example).
# IP 62.171.186.233 · SSH : ./scripts/ssh-contabo.sh
MEDIA_BACKEND_URL=http://62.171.186.233/cppeurope-staging/api/media/getMedia
MEDIA_LOCALE_BACKEND_URL=http://62.171.186.233/cppeurope-staging/api/media-locale/getMedia
MEDIA_API_CONTABO=http://62.171.186.233/cppeurope-staging/api/media
