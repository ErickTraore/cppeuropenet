# Cypress E2E env (staging)
# Utilisation:
#   cp .env.cypress.staging.example .env.cypress.staging
#   CYPRESS_ENV_FILE=.env.cypress.staging npm --prefix hostinger-cppeurope/frontend run e2e:cold

# Front staging (URL/port exposes par nginx staging)
HOSTINGER_FRONTEND_HOST=staging.cppeurope.net
HOSTINGER_FRONTEND_PORT=80
HOSTINGER_FRONTEND_BASE_PATH=/cppeurope-staging

# User backend via front/proxy staging
HOSTINGER_USER_BACKEND_PORT=80

# Appels directs backend E2E (adapter selon votre topologie staging)
E2E_BACKEND_HOST=staging.cppeurope.net
E2E_PORT_MEDIA_GLE=80
E2E_PORT_MEDIA_LOCALE=80
E2E_PORT_PRESSE_GENERALE=80
E2E_PORT_PRESSE_LOCALE=80
E2E_PORT_USER_MEDIA_PROFILE=80
E2E_PORT_USER_BACKEND=80

# Home-config origin (direct service ou via proxy)
CYPRESS_HOME_CONFIG_ORIGIN=http://staging.cppeurope.net

# Origin de probe pour le test CORS (spec 006)
CYPRESS_CORS_PROBE_ORIGIN=https://staging.cppeurope.net

# Gate infra (optionnel)
# CYPRESS_E2E_GATE_MAX_MS=240000
# CYPRESS_E2E_GATE_POLL_MS=2000