# Cypress E2E env (local)
# Copier vers .env.cypress puis ajuster si besoin.

# Front hostinger
# Sur certaines machines macOS, 127.0.0.1:8082 peut etre capte par un process IDE.
HOSTINGER_FRONTEND_HOST=localhost
HOSTINGER_FRONTEND_PORT=8082
# Prefixe de chemin frontend (laisser vide en local)
# HOSTINGER_FRONTEND_BASE_PATH=
HOSTINGER_USER_BACKEND_PORT=17001

# Hote des backends Contabo pour les appels directs Cypress
E2E_BACKEND_HOST=127.0.0.1

# Ports Contabo / services
E2E_PORT_MEDIA_GLE=7004
E2E_PORT_MEDIA_LOCALE=7008
E2E_PORT_PRESSE_GENERALE=17012
E2E_PORT_PRESSE_LOCALE=7005
E2E_PORT_USER_MEDIA_PROFILE=7017
E2E_PORT_USER_BACKEND=17001

# Home-config backend direct (teardown spec 042)
CYPRESS_HOME_CONFIG_ORIGIN=http://127.0.0.1:7020

# Origin de probe pour le test CORS (spec 006)
CYPRESS_CORS_PROBE_ORIGIN=http://localhost:3000

# Gate infra (optionnel)
# CYPRESS_E2E_GATE_MAX_MS=180000
# CYPRESS_E2E_GATE_POLL_MS=2000