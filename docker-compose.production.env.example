# Copier vers docker-compose.production.env (non versionné) et adapter.
# Démarrage : ./scripts/production-compose.sh up -d
# ou : docker compose --env-file ./docker-compose.production.env -f docker-compose.yml up -d
#
# L’interpolation des variables ${…} dans docker-compose.yml lit ce fichier via --env-file
# (pas les env_file des services, qui ne servent qu’aux conteneurs).

# --- Ports hôte → conteneur ---
COMPOSE_MARIADB_HOST_PORT=3314
COMPOSE_NGINX_HOST_PORT=8085
COMPOSE_FRONTEND_HOST_PORT=8082
COMPOSE_ADMINER_HOST_PORT=8083
COMPOSE_ADMINER_DB_HOST=mariadb

# --- MariaDB (image officielle) — aligner avec user-backend si besoin ---
MARIADB_DATABASE=user_dev_cppeurope_v1
MARIADB_USER=c
MARIADB_PASSWORD=CppEurope@2025!
MARIADB_ROOT_PASSWORD=RootPass@2025!

# --- CORS (surcharges explicites pour les services Docker ; user-backend charge aussi .env.production) ---
COMPOSE_USER_BACKEND_ALLOWED_ORIGINS=https://cppeurope.net,https://www.cppeurope.net,http://localhost:8082,http://localhost:3000
COMPOSE_HOME_CONFIG_ALLOWED_ORIGINS=https://cppeurope.net,https://www.cppeurope.net,http://localhost:8082,http://localhost:3000,http://localhost:8085,http://127.0.0.1:8082,http://127.0.0.1:8085

# --- Node (surcharges compose) ---
COMPOSE_USER_BACKEND_NODE_ENV=production
COMPOSE_HOME_CONFIG_NODE_ENV=production

# --- home-config (service) ---
COMPOSE_HOME_CONFIG_PORT=7020
COMPOSE_HOME_CONFIG_DATA_DIR=/data
COMPOSE_HOME_CONFIG_MAX_UPLOAD_MB=50

# --- Frontend (server.prod.js) : proxy vers Contabo / APIs presse ---
NODE_ENV=production
REACT_APP_USER_API=/api/users
USER_BACKEND_HOST=user-backend
USER_BACKEND_PORT=7001
HOME_CONFIG_HOST=home-config
HOME_CONFIG_PORT=7020
PROXY_UPSTREAM_HOST_HEADER=cppeurope.net
MEDIA_STATIC_HOST=62.171.186.233
MEDIA_STATIC_PORT=80
MEDIA_HEALTH_PATH=/api/user-media-profile/
PRESSE_MEDIA_GLE_HOST=62.171.186.233
PRESSE_MEDIA_GLE_PORT=80
PRESSE_MEDIA_LOC_HOST=62.171.186.233
PRESSE_MEDIA_LOC_PORT=80
PRESSE_LOCALE_MSG_HOST=62.171.186.233
PRESSE_LOCALE_MSG_PORT=80
PRESSE_GENERALE_HOST=62.171.186.233
PRESSE_GENERALE_PORT=80
