# Copier vers docker-compose.staging.env (non versionné) et adapter.
# Utilisé en second fichier après user-backend/.env.staging par ./scripts/staging-compose.sh
# (ports, frontend, préfixe Contabo — pas de secrets DB ici : rester dans user-backend/.env.staging).
#
# Démarrage manuel :
#   docker compose --env-file ./user-backend/.env.staging --env-file ./docker-compose.staging.env -f docker-compose.staging.yml -p cppeurope-staging up -d

# --- Ports hôte ---
COMPOSE_MARIADB_HOST_PORT=3315
COMPOSE_NGINX_HOST_PORT=9085
COMPOSE_FRONTEND_HOST_PORT=9082
COMPOSE_ADMINER_HOST_PORT=9083

# --- user-backend (surcharges compose ; le reste vient de user-backend/.env.staging) ---
NODE_ENV=production
DB_HOST=mariadb

# --- home-config (service) ---
COMPOSE_HOME_CONFIG_NODE_ENV=production
COMPOSE_HOME_CONFIG_PORT=7020
COMPOSE_HOME_CONFIG_DATA_DIR=/data
COMPOSE_HOME_CONFIG_MAX_UPLOAD_MB=50

# --- adminer ---
COMPOSE_ADMINER_DB_HOST=mariadb

# --- Frontend staging (server.prod.js) : NODE_ENV ci-dessus (section user-backend) sert aussi à l’interpolation du service frontend ---
REACT_APP_USER_API=/api/users
USER_BACKEND_HOST=user-backend
USER_BACKEND_PORT=7001
HOME_CONFIG_HOST=home-config
HOME_CONFIG_PORT=7020
PROXY_UPSTREAM_HOST_HEADER=cppeurope.net
CONTABO_PATH_PREFIX=/cppeurope-staging
MEDIA_STATIC_HOST=62.171.186.233
MEDIA_STATIC_PORT=80
MEDIA_HEALTH_PATH=/api/user-media-profile/
PRESSE_MEDIA_GLE_HOST=62.171.186.233
PRESSE_MEDIA_GLE_PORT=80
PRESSE_MEDIA_LOC_HOST=62.171.186.233
PRESSE_MEDIA_LOC_PORT=80
PRESSE_LOCALE_MSG_HOST=62.171.186.233
PRESSE_LOCALE_MSG_PORT=80
PRESSE_GENERALE_HOST=62.171.186.233
PRESSE_GENERALE_PORT=80
